{
  "__inputs": [],
  "__requires": [],
  "title": "HyperPush",
  "description": "HyperPush production monitoring — log volume, error rates, and container insights",
  "tags": ["hyperpush", "production"],
  "schemaVersion": 39,
  "version": 1,
  "uid": "hyperpush-dashboard",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 0,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "templating": {
    "list": [
      {
        "name": "compose_project",
        "type": "query",
        "query": "label_values(compose_project)",
        "current": { "value": "hyperpush", "text": "hyperpush" },
        "datasource": {
          "type": "loki",
          "uid": "P8E80F9AEF21F6940"
        },
        "label": "Compose Project",
        "refresh": 2,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "container",
        "type": "query",
        "query": "label_values(container)",
        "current": { "value": "", "text": "All" },
        "datasource": {
          "type": "loki",
          "uid": "P8E80F9AEF21F6940"
        },
        "label": "Container",
        "refresh": 2,
        "includeAll": true,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Log Volume (5m rate)",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "options": {
        "legend": { "calcs": ["max", "mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "rate({compose_project=\"$compose_project\"}[5m])",
          "legendFormat": "all logs"
        },
        {
          "expr": "rate({compose_project=\"$compose_project\"} | json | level = \"error\" [5m])",
          "legendFormat": "errors"
        },
        {
          "expr": "rate({compose_project=\"$compose_project\"} | json | level = \"warn\" [5m])",
          "legendFormat": "warnings"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate by Container (5m)",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "options": {
        "legend": { "calcs": ["max", "mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (rate({compose_project=\"$compose_project\"} | json | level = \"error\" [5m]))",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Errors (24h)",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "count_over_time({compose_project=\"$compose_project\"} | json | level = \"error\" [$__range])",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total Warnings (24h)",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "count_over_time({compose_project=\"$compose_project\"} | json | level = \"warn\" [$__range])",
          "legendFormat": "warnings"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total Log Lines (24h)",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "blue", "value": 10000 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "count_over_time({compose_project=\"$compose_project\"} [$__range])",
          "legendFormat": "total logs"
        }
      ]
    },
    {
      "id": 6,
      "title": "Top Containers by Log Count (1h)",
      "type": "table",
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "options": {
        "sortBy": [{ "displayName": "Value #A", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10000 },
              { "color": "red", "value": 50000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "topk(10, sum by (container) (count_over_time({compose_project=\"$compose_project\"}[1h])))",
          "legendFormat": "log lines",
          "format": "table"
        }
      ]
    },
    {
      "id": 7,
      "title": "Recent Errors",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "gridPos": { "h": 14, "w": 12, "x": 12, "y": 14 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessages": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{compose_project=\"$compose_project\"} | json | level = \"error\"",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 8,
      "title": "Log Stream (All Containers)",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "gridPos": { "h": 14, "w": 12, "x": 0, "y": 22 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessages": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{compose_project=\"$compose_project\"} | json",
          "legendFormat": ""
        }
      ]
    }
  ]
}
