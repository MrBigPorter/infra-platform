# ==========================================
# infra-platform — 环境变量模板
# ==========================================
# cp .env.example .env.prod   ← 生产
# cp .env.example .env        ← 本地开发
# ==========================================

# Grafana Admin 密码（首次登录用）
GRAFANA_ADMIN_PASSWORD="change-me-to-a-strong-password"

# Grafana SSO 密钥（必须和 HyperPush backend/.env 保持一致）
# 生成: openssl rand -hex 32
GRAFANA_AUTH_SECRET="change-me-to-a-random-secret"
